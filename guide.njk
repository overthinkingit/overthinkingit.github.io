---
layout: layouts/page.njk
title: Guide
navSection: guide
description: A suggested trajectory through these pages — where to begin, what to prioritize, and which ideas are worth waiting for.
permalink: /guide/
---

<header class="page-header">
  <p class="page-header__eyebrow">{{ guide.eyebrow }}</p>
  <h1 class="page-header__title">{{ guide.title }}</h1>
  <p class="page-header__subtitle">{{ guide.subtitle }}</p>
</header>

<article>

{% for paragraph in guide.intro %}
<p>{{ paragraph | safe }}</p>
{% endfor %}

{% for stage in guide.stages %}
<section class="guide-stage">
  <h2>{{ stage.number }}. {{ stage.name }}</h2>
  <p class="guide-stage__intro">{{ stage.intro }}</p>
  <ul class="guide-items">
    {% for item in stage.items %}
    {% if item.planned %}
    <li class="guide-item guide-item--planned">
      <span class="guide-item__badge">Planned</span>
      <span class="guide-item__title">{{ item.title }}</span>
      <span class="guide-item__annotation">{{ item.annotation | safe }}</span>
    </li>
    {% else %}
    <li class="guide-item{% if item.optional %} guide-item--optional{% endif %}" data-guide-url="{{ item.url }}">
      <button
        type="button"
        class="guide-item__check"
        aria-label="Mark as read"
        aria-pressed="false"
      ></button>
      <a class="guide-item__link" href="{{ item.url }}">
        {% if item.optional %}<span class="guide-item__badge">Optional</span>{% endif %}
        {% if item.meta %}<span class="guide-item__meta">{{ item.meta }}</span>{% endif %}
        <span class="guide-item__title">{{ item.title }}</span>
        <span class="guide-item__annotation">{{ item.annotation | safe }}</span>
      </a>
    </li>
    {% endif %}
    {% endfor %}
  </ul>
</section>
{% endfor %}

<hr>

<p>{{ guide.closing | safe }}</p>

</article>
